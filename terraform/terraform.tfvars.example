# terraform.tfvars.example
# Copy to terraform.tfvars (DO NOT COMMIT) and fill values, or use env vars / AWS profile.

# AWS auth (preferred: AWS_PROFILE or env vars; keep empty if using default provider chain)
aws_access_key     = ""
aws_secret_key     = ""
aws_session_token  = ""

# EC2 keypair name (must exist in the target AWS region)
ssh_key_name = "example-platform-keypair"

# Security group name for the example environment
ec2_security_group_name = "sg-example-platform"
