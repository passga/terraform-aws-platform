# terraform.tfvars.example
# Copy to terraform.tfvars (DO NOT COMMIT) and fill values, or use env vars / AWS profile.

# AWS auth (preferred: AWS_PROFILE or env vars; keep empty if using default provider chain)
aws_access_key     = ""
aws_secret_key     = ""
aws_session_token  = ""

# Rancher server public DNS name (after AWS apply, use the output)
rancher_server_dns = "ec2-xx-xxx-xx-xx.eu-west-1.compute.amazonaws.com"

# Admin password for Rancher (store securely; do not commit)
rancher_server_admin_password = "CHANGE_ME"

# EC2 keypair name (must exist in the target AWS region)
ec2_keypair = "perf-env-keypair"

# Security group name for the perf environment
ec2_security_group_name = "sg_perf-environment"
