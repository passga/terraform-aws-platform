# Required variables
# - Fill in before beginning perf-provisioning
# ==========================================================

# AWS Session Key
# aws_session_token = ""


# Rancher server dns
rancher_server_dns=""

# Password used to log in to the `admin` account on the new Rancher server
rancher_server_admin_password=""

### Location of pem private file using for all ssh connexion
ssh_private_key_file=""

# Password used to log in to the `admin` account on the new Rancher server
rancher_server_admin_password = ""


# Name of pem attached to all new ec2 instances created
ec2_keypair = "bonita-perf-env"

# Security group used by perf environment
ec2_security_group_name = "sg_perf-environment"

# Optional variables, uncomment to customize the perf-provisioning
# ----------------------------------------------------------

# AWS region for all resources
# aws_region = ""

# Prefix for all resources created by perf-provisioning
# prefix = ""

# EC2 instance size of all created instances
# instance_type = ""

# EC2 instance size for rancher server
#rancher_server_instance_type =""

# EC2 instance size for all performance nodes
# workload_nodes_instance_type =""



# Docker version installed on target hosts
# - Must be a version supported by the Rancher install scripts
# docker_version = ""

# Kubernetes version used for creating management server cluster
# - Must be supported by RKE terraform provider 1.0.1
# rancher_kubernetes_version = ""

# Kubernetes version used for creating workload cluster
# - Must be supported by RKE terraform provider 1.0.1
# workload_kubernetes_version = ""

# Version of cert-manager to install, used in case of older Rancher versions
# cert_manager_version = ""

# Version of Rancher to install
# rancher_version = ""

### Cluster name to use for deployment of nodes
#workload_cluster_name= "performance"
