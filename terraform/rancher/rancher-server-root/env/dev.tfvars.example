# Reuse the kubeconfig generated by aws-root
kubeconfig_path = "../../aws-root/kube/k3s.yaml"

# DNS name for Rancher. nip.io works for quick tests.
rancher_hostname = "rancher.<AWS_PUBLIC_IP>.nip.io"

# Helm/bootstrap settings
rancher_version            = "v2.9.2"
rancher_bootstrap_insecure = true
letsencrypt_email          = "you@example.com"
letsencrypt_environment    = "staging"
